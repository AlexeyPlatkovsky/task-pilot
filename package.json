{
  "name": "taskpilot",
  "version": "0.0.0",
  "description": "Local-first, file-based task management. Markdown/YAML files are the source of truth.",
  "license": "SEE LICENSE IN LICENSE",
  "bin": {
    "taskpilot": "./bin/taskpilot"
  },
  "files": [
    "bin/",
    "src/",
    "requirements.lock",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
